{
  "name": "athleon",
  "version": "1.0.0",
  "private": true,
  "description": "Athléon — Sports Ecosystem Platform",
  "workspaces": [
    "server",
    "client",
    "owner",
    "admin"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:owner": "npm run dev --workspace=owner",
    "dev:admin": "npm run dev --workspace=admin",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:owner": "npm run build --workspace=owner",
    "build:admin": "npm run build --workspace=admin",
    "build": "concurrently \"npm:build:server\" \"npm:build:client\" \"npm:build:owner\" \"npm:build:admin\"",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
